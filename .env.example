# Database
DATABASE_URL=postgresql://user:password@localhost:5432/apphub

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS and invite links)
CLIENT_URL=http://localhost:5173

# File uploads (app HTML is stored in DB; this is only used for workspace logos)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# AI Conversion (Pro feature — used by /api/apps/convert)
ANTHROPIC_API_KEY=sk-ant-...

# Tiered LLM Converter (used by /api/convert)
TIER1_PROVIDER=gemini
TIER1_MODEL=gemini-2.5-flash
TIER1_API_KEY=
TIER1_MAX_TOKENS=65536
TIER1_COST_INPUT=0.00015
TIER1_COST_OUTPUT=0.0006

TIER2_PROVIDER=anthropic
TIER2_MODEL=claude-sonnet-4-6-20250514
TIER2_API_KEY=
TIER2_MAX_TOKENS=64000
TIER2_COST_INPUT=0.003
TIER2_COST_OUTPUT=0.015

# Alternatively, TIER1_API_KEY / TIER2_API_KEY fall back to:
GEMINI_API_KEY=

# Email (Resend — free tier: 3,000 emails/month)
RESEND_API_KEY=re_...
EMAIL_FROM=AppHub <onboarding@resend.dev>

# Stripe (subscription billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Testing (used by npm test)
# DATABASE_URL=postgresql://testuser:testpass@localhost:5432/apphub_test
# JWT_SECRET=test-secret-key
# NODE_ENV=test
